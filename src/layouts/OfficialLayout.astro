---
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  title: string;
  description?: string;
  section?: string;
}

const { title, description, section } = Astro.props;

const nav = [
  { name: "about",         href: "/official/" },
  { name: "publications",  href: "/official/publications/" },
  { name: "talks",         href: "/official/talks/" },
  { name: "teaching",      href: "/official/teaching/" },
  { name: "cv",            href: "/official/cv/" },
];
---
<BaseLayout title={title} description={description}>
  <main class="page">
    <header class="site-header">
      <a class="brand" href="/official/">Christopher Z. Cui</a>
      <nav>
        {nav.map((n) => (
          <a href={n.href} class={section === n.name ? "active" : ""}>{n.name}</a>
        ))}
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <span>czcui@ucsd.edu &nbsp;·&nbsp; UC San Diego</span>
      <a class="mode-toggle" href="/adventure/">switch to adventure mode &rarr;</a>
    </footer>
  </main>
</BaseLayout>
