---
import AdventureLayout from "../../layouts/AdventureLayout.astro";
import RoomNav from "../../components/RoomNav.astro";
import { getCollection } from "astro:content";

const talks = (await getCollection("talks")).sort(
  (a, b) => +b.data.date - +a.data.date,
);
const fmt = (d: Date) => d.toLocaleDateString("en-US", { year: "numeric", month: "long" });
---
<AdventureLayout title="Talks — Adventure" description="The slide deck.">
  <p class="room-title">The Slide Deck</p>

  <div class="desc">{`You wake the workstation. A presenter view glows back at you.
The thumbnails fade in, sorted newest first.`}</div>

  <ul class="entry-list" style="margin-top: 1.5em;">
    {talks.map(async (t) => {
      const { Content } = await t.render();
      return (
        <li>
          <div class="entry-title">{t.data.title}</div>
          <div class="entry-meta">
            {fmt(t.data.date)} · {t.data.venue}
            {t.data.location && <> · {t.data.location}</>}
          </div>
          <div class="entry-excerpt">
            <Content />
          </div>
        </li>
      );
    })}
  </ul>

  <RoomNav />
</AdventureLayout>
