---
import OfficialLayout from "../../../layouts/OfficialLayout.astro";
import { getCollection } from "astro:content";

const all = await getCollection("publications");
const pubs = all.sort((a, b) => +b.data.date - +a.data.date);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short" });
---
<OfficialLayout
  title="Publications"
  section="publications"
  description="Selected publications by Christopher Z. Cui."
>
  <article class="prose">
    <h1>Publications</h1>
    <p>
      A complete list is on
      <a href="https://scholar.google.com/citations?user=uGTn8fUAAAAJ&hl=en">Google Scholar</a>.
      A starred (*) marker indicates equal or shared first authorship.
    </p>

    <ul class="entry-list">
      {pubs.map((p) => (
        <li>
          <div class="entry-title">
            {p.data.paperurl
              ? <a href={p.data.paperurl} rel="noopener">{p.data.title}</a>
              : <span>{p.data.title}</span>}
          </div>
          <div class="entry-meta">
            {fmt(p.data.date)} &middot; {p.data.venue}
          </div>
          {p.data.authors && (
            <div class="entry-meta" style="margin-top: -0.2em;">{p.data.authors}</div>
          )}
          <p class="entry-excerpt" set:html={p.data.excerpt} />
        </li>
      ))}
    </ul>
  </article>
</OfficialLayout>
